#!groovy

properties([
  // H allow predefined but random minute see https://en.wikipedia.org/wiki/Cron#Non-standard_characters
  pipelineTriggers([cron('H 07 * * 1-5')])
])

@Library("Infrastructure")

def type = "java"
def product = "camunda"
def component = "bpm"

def channel = '#platops-build-notices'

def secrets = [
    secret('camunda-enterprise-user', 'CAMUNDA_NEXUS_USER'),
    secret('camunda-enterprise-password', 'CAMUNDA_NEXUS_PASSWORD'),
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withNightlyPipeline(type, product, component) {
  before('build') {
    withAzureKeyvault(
      azureKeyVaultSecrets: secrets,
      keyVaultURLOverride: 'https://rpe-prod.vault.azure.net'
    ) {
      env.CAMUNDA_NEXUS_USER = "${CAMUNDA_NEXUS_USER}"
      env.CAMUNDA_NEXUS_PASSWORD = "${CAMUNDA_NEXUS_PASSWORD}"
      echo 'Camunda EE credentials loaded for Gradle (CAMUNDA_NEXUS_USER / CAMUNDA_NEXUS_PASSWORD)'
    }
  }
  
 env.S2S_URL = "http://rpe-service-auth-provider-aat.service.core-compute-aat.internal"
 env.TASK_MANAGEMENT_API_URL = "http://wa-task-management-api-aat.service.core-compute-aat.internal"

  enableSlackNotifications(channel)
}
