#!groovy

@Library("Infrastructure") _

def type = "java"
def product = "camunda"
def component = "bpm"

def secrets = [
        secret('camunda-enterprise-user', 'CAMUNDA_NEXUS_USER'),
        secret('camunda-enterprise-password', 'CAMUNDA_NEXUS_PASSWORD'),
]

def vaultSecrets = [
        's2s-${env}': [
                secret('microservicekey-camunda-bpm', 'S2S_SECRET_CAMUNDA_BPM'),
        ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [
            secretType: 'Secret',
            name: secretName,
            version: '',
            envVariable: envVar
    ]
}


withParameterizedPipeline(type, product, component, "sandbox", "sandbox") {
    loadVaultSecrets(vaultSecrets)

    before('build') {
        withAzureKeyvault(
            azureKeyVaultSecrets: secrets,
            keyVaultURLOverride: 'https://rpe-prod.vault.azure.net'
        ) {
            env.CAMUNDA_NEXUS_USER = "${CAMUNDA_NEXUS_USER}"
            env.CAMUNDA_NEXUS_PASSWORD = "${CAMUNDA_NEXUS_PASSWORD}"
            echo 'Camunda EE credentials loaded for Gradle (CAMUNDA_NEXUS_USER / CAMUNDA_NEXUS_PASSWORD)'
        }
    }

}
